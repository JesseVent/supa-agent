{
    "name": "root",
    "private": true,
    "version": "1.8.2",
    "type": "module",
    "workspaces": [
        "packages/page-controller",
        "packages/ui",
        "packages/llms",
        "packages/core",
        "packages/supa-agent",
        "packages/mcp",
        "packages/skill-router",
        "packages/extension"
    ],
    "description": "AI-powered UI agent for web applications",
    "author": "Jesse Vent",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/JesseVent/supa-agent.git"
    },
    "homepage": "https://github.com/JesseVent/supa-agent",
    "engines": {
        "node": "^22.13.0 || >=24"
    },
    "scripts": {
        "dev:ext": "npm run dev -w @supa-agent/ext",
        "dev:demo": "npm run dev:demo --workspace=supa-agent",
        "build": "node scripts/build.js",
        "build:libs": "node scripts/build-libs.js",
        "build:ext": "npm run zip -w @supa-agent/ext",
        "version": "node scripts/sync-version.js",
        "prepublishOnly": "node scripts/publish-guard.js",
        "postpublish": "npm run postpublish --workspaces --if-present",
        "typecheck": "tsc --noEmit -p tsconfig.typecheck.json && tsc --noEmit -p packages/extension/tsconfig.json",
        "lint": "biome check .",
        "test": "vitest run",
        "format": "biome format --write .",
        "format:check": "biome format .",
        "ci": "node scripts/ci.js",
        "cleanup": "rm -rf packages/*/dist && rm -rf packages/*/.output",
        "prepare": "husky || true"
    },
    "devDependencies": {
        "@biomejs/biome": "^2.4.16",
        "@commitlint/cli": "^20.5.3",
        "@commitlint/config-conventional": "^20.5.3",
        "@microsoft/api-extractor": "^7.58.8",
        "@tailwindcss/vite": "^4.3.0",
        "@types/node": "^25.9.2",
        "@vitejs/plugin-react": "^6.0.2",
        "chalk": "^5.6.2",
        "concurrently": "^9.2.1",
        "dotenv": "^17.4.2",
        "husky": "^9.1.7",
        "lint-staged": "^16.4.0",
        "typescript": "^6.0.3",
        "unplugin-dts": "^1.0.2",
        "vite": "^8.0.16",
        "vite-plugin-css-injected-by-js": "^5.0.1",
        "vitest": "^4.1.8",
        "wxt": "^0.20.26"
    },
    "overrides": {
        "typescript": "^6.0.3"
    },
    "lint-staged": {
        "*.{js,ts,cjs,cts,mjs,mts,jsx,tsx}": [
            "biome check --write --no-errors-on-unmatched"
        ],
        "*.{json,css}": [
            "biome format --write --no-errors-on-unmatched"
        ]
    },
    "commitlint": {
        "extends": [
            "@commitlint/config-conventional"
        ],
        "rules": {
            "subject-case": [
                0,
                "never"
            ]
        }
    }
}
