{
    "name": "@supa-agent/llms",
    "version": "1.8.2",
    "type": "module",
    "main": "./src/index.ts",
    "types": "./src/index.ts",
    "exports": {
        ".": {
            "types": "./src/index.ts",
            "default": "./src/index.ts"
        }
    },
    "publishConfig": {
        "main": "./dist/lib/supa-agent-llms.js",
        "module": "./dist/lib/supa-agent-llms.js",
        "types": "./dist/lib/index.d.ts",
        "exports": {
            ".": {
                "types": "./dist/lib/index.d.ts",
                "import": "./dist/lib/supa-agent-llms.js",
                "default": "./dist/lib/supa-agent-llms.js"
            }
        }
    },
    "files": [
        "dist/"
    ],
    "description": "LLM client with reflection-before-action mental model for SupaAgent",
    "keywords": [
        "supa-agent",
        "llm",
        "openai",
        "tool-calling",
        "agent"
    ],
    "author": "Jesse Vent",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/JesseVent/supa-agent.git",
        "directory": "packages/llms"
    },
    "homepage": "https://github.com/JesseVent/supa-agent",
    "scripts": {
        "build": "vite build",
        "prepublishOnly": "node ../../scripts/publish-guard.js && node ../../scripts/pre-publish.js",
        "postpublish": "node ../../scripts/post-publish.js"
    },
    "dependencies": {
        "chalk": "^5.6.2"
    },
    "peerDependencies": {
        "zod": "^3.25.0 || ^4.0.0"
    },
    "devDependencies": {
        "zod": "^4.4.3"
    }
}
